{
  "title": "Spark Application Logs",
  "uid": "data-on-eks-spark-logs",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "search",
        "type": "textbox",
        "label": "Search messages",
        "current": { "value": "" }
      },
      {
        "name": "spark_filter",
        "type": "adhoc",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-events" },
        "defaultKeys": [
          { "text": "namespace", "value": "namespace" },
          { "text": "app", "value": "app" },
          { "text": "level", "value": "level" },
          { "text": "role", "value": "role" },
          { "text": "node_name", "value": "node_name" },
          { "text": "pod_name", "value": "pod_name" },
          { "text": "container_name", "value": "container_name" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Rate by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-events" },
      "targets": [
        {
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, level, count() AS logs FROM app_logs.spark WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY time, level ORDER BY time",
          "format": 0,
          "refId": "A",
          "meta": { "database": "app_logs", "table": "spark" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Logs by Application",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-events" },
      "targets": [
        {
          "rawSql": "SELECT app, count() AS logs FROM app_logs.spark WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY app ORDER BY logs DESC LIMIT 20",
          "format": 1,
          "refId": "A",
          "meta": { "database": "app_logs", "table": "spark" }
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "reduceOptions": { "values": true, "calcs": [] },
        "pieType": "pie"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "app" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": false, "tooltip": false, "viz": true } }]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "Spark Logs",
      "type": "table",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-events" },
      "targets": [
        {
          "rawSql": "SELECT timestamp, level, namespace, app, role, pod_name, container_name, node_name, message, log FROM app_logs.spark WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND ('${search:raw}' = '' OR message ILIKE '%${search:raw}%') ORDER BY timestamp DESC LIMIT 500",
          "format": 1,
          "refId": "A",
          "meta": { "database": "app_logs", "table": "spark" }
        }
      ],
      "options": { "showHeader": true, "sortBy": [{ "displayName": "timestamp", "desc": true }] },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "message" }, "properties": [{ "id": "custom.width", "value": 500 }] },
          { "matcher": { "id": "byName", "options": "level" }, "properties": [{ "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "log" }, "properties": [{ "id": "custom.width", "value": 400 }] }
        ]
      }
    }
  ]
}
