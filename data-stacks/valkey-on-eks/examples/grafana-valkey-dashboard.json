  },
  "description": "Valkey Cluster overview dashboard for Data on EKS. Visualizes cluster health, replication, memory, throughput, hit-rate, uptime, and backup recency for the Bitnami valkey-cluster chart's bundled exporter. NOTE: the Bitnami Valkey exporter is built on top of the Redis exporter, so depending on the chart/exporter version the metric prefix may be either 'valkey_' (newer images) or 'redis_' (older images). If panels show 'No data', edit each panel's PromQL and replace the 'valkey_' prefix with 'redis_' (e.g. valkey_cluster_state -> redis_cluster_enabled, valkey_memory_used_bytes -> redis_memory_used_bytes, valkey_keyspace_hits_total -> redis_keyspace_hits_total).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cluster state reported by the Valkey exporter. 1 = ok, 0 = fail. Drives the ValkeyClusterStateNotOk alert.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 1,
                  "text": "FAIL"
                },
                "1": {
                  "color": "green",
                  "index": 0,
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "min(valkey_cluster_state{namespace=~\"$namespace\",service=~\"$service\"})",
          "legendFormat": "cluster_state",
          "refId": "A"
        }
      ],
      "title": "Cluster State",
      "type": "stat"
    },
