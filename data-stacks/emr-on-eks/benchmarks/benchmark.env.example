# Copy this file to `benchmark.env` and fill in the environment-specific values.
# `benchmark.env` is intended to stay local and should not be committed.

# Cluster-specific benchmark inputs
EMR_VIRTUAL_CLUSTER_ID="<emr-virtual-cluster-id>"
EMR_EXECUTION_ROLE_ARN="arn:aws:iam::<account-id>:role/<execution-role>"
CLOUDWATCH_LOG_GROUP="/emr-on-eks-logs/emr-on-eks/<team>"
S3_BUCKET="s3://<benchmark-bucket>"
AWS_REGION="<aws-region>"
EMR_BASE_IMAGE="<emr-base-image-uri>"
ECR_IMAGE="<benchmark-image-uri>"
TPCDS_INPUT="s3://<input-dataset-bucket>/<path>"

# Benchmark run shape
LOCUST_USERS="3000"
LOCUST_SPAWN_RATE="1.67"
LOCUST_RUN_TIME="30m"
MAX_JOBS_TO_SUBMIT="3000"
TPCDS_QUERIES="q4-v2.4,q24a-v2.4,q24b-v2.4,q67-v2.4"
